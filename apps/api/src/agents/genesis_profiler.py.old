    def _get_session(self, session_id: str) -> IntegratedSession:            target_layer="Orchestrator",

        """Get or create an integrated session with all fractal components."""            insight_type=insight_type,

        if session_id not in self._sessions:            confidence_score=confidence,

            session = IntegratedSession(session_id=session_id)            payload=payload,

            self._sessions[session_id] = session            hrm_validated=hrm_validated,

            logger.info(f"[GenesisProfiler] Created session: {session_id}")        )

        
        return self._sessions[session_id]
    
    def clear_session(self, session_id: str) -> bool:
        """Clear all state for a session - complete reset."""
        if session_id in self._sessions:
            del self._sessions[session_id]
            logger.info(f"[GenesisProfiler] Cleared session: {session_id}")
            return True
        return False
    
    def get_session_summary(self, session_id: str) -> Optional[dict]:
        """Get session summary for debugging/monitoring."""
        if session_id in self._sessions:
            return self._sessions[session_id].to_summary()
        return None
    
    # =========================================================================
    # MESSAGE CLASSIFICATION
    # =========================================================================
    
    def _is_init_message(self, message: str) -> bool:
        """Check if this is a system initialization message (not real user input)."""
        if not message or not message.strip():
            return True
        
        init_keywords = [
            "begin the genesis",
            "introduce yourself",
            "first interaction",
            "start the profiling",
            "initiate genesis",
            "begin profiling",
            "generate the next",
            "very first interaction",
            "start the journey",
            "begin our exploration",
        ]
        message_lower = message.lower().strip()
        return any(keyword in message_lower for keyword in init_keywords)
    
    # =========================================================================
    # FRACTAL PROCESSING PIPELINE
    # =========================================================================
    
    async def _run_profiler_analysis(
        self,
        session: IntegratedSession,
        user_message: str,
    ) -> list[Signal]:
        """
        Run the Profiler (Scout) to silently detect patterns.
        
        The Profiler scans for:
        - HD Type indicators (Generator, Projector, etc.)
        - Jungian function markers (Ni, Ne, Ti, etc.)
        - Energy pattern signals (sustainable, burst, wave)
        - Somatic/nervous system cues
        """
        profiler = session.core.profiler
        signals = profiler.analyze_message(user_message, session.genesis_state)
        
        # Update session metrics
        session.total_signals_detected += len(signals)
        
        if signals:
            logger.info(f"[GenesisProfiler] Profiler detected {len(signals)} signals")
            for signal in signals:
                logger.debug(f"  - {signal.signal_type}: {signal.suggested_traits}")
        
        return signals
    
    def _convert_signals_to_hypotheses(
        self,
        session: IntegratedSession,
        signals: list[Signal],
    ) -> list[Hypothesis]:
        """Convert detected signals into hypotheses for verification."""
        hypothesis_engine = session.core.hypothesis_engine
        
        for signal in signals:
            for trait_name, value in signal.suggested_traits.items():
                hypothesis_engine.add_hypothesis(
                    trait_name=trait_name,
                    suspected_value=value,
                    confidence=signal.confidence * 0.7,  # Discount initial confidence
                    evidence=[signal.content[:200]],  # Truncated evidence
                )
        
        # Get active hypotheses sorted by priority
        active = hypothesis_engine.get_top_hypotheses(limit=5)
        session.total_hypotheses_created = len(hypothesis_engine.hypotheses)
        
        return active
    
    def _should_probe(self, session: IntegratedSession, hypotheses: list[Hypothesis]) -> bool:
        """Decide whether to generate a probe question vs. conversational response."""
        if not hypotheses:
            return False
        
        state = session.genesis_state
        
        # Always probe more in MAPPING phase
        if state.phase == GenesisPhase.MAPPING:
            return True
        
        # Probe every 3rd turn in other phases
        if state.conversation_turn > 0 and state.conversation_turn % 3 == 0:
            return True
        
        # Probe if we have a high-priority hypothesis
        top_hypothesis = hypotheses[0] if hypotheses else None
        if top_hypothesis and top_hypothesis.priority > 0.8:
            return True
        
        return False
    
    async def _generate_probe(
        self,
        session: IntegratedSession,
        hypotheses: list[Hypothesis],
    ) -> tuple[str, list[dict]]:
        """Generate a probe question using the HypothesisEngine."""
        hypothesis_engine = session.core.hypothesis_engine
        
        probe_packet = hypothesis_engine.generate_probe(session.genesis_state)
        
        if not probe_packet:
            # Fallback to conversational response
            return await self._generate_conversational_response(session, "")
        
        probe_data = probe_packet.payload.get("probe", {})
        prompt = probe_data.get("prompt", "Tell me more about that...")
        probe_type = probe_data.get("probe_type", "confirmation")
        options = probe_data.get("options", [])
        hypothesis_id = probe_data.get("hypothesis_id")
        
        # Update metrics
        session.total_probes_sent += 1
        
        # Build UI components based on probe type
        components = [
            {"type": "text", "content": prompt, "variant": "question"},
        ]
        
        if probe_type == "binary_choice" and len(options) >= 2:
            components.append({
                "type": "choice_cards",
                "options": [
                    {"id": "a", "label": options[0], "icon": "🌊"},
                    {"id": "b", "label": options[1], "icon": "⚡"},
                ],
                "allowMultiple": False,
            })
        elif probe_type == "slider":
            components.append({
                "type": "slider",
                "min": 1,
                "max": 10,
                "defaultValue": 5,
                "label": "How strongly does this resonate?",
            })
        elif probe_type == "card_selection":
            components.append({
                "type": "choice_cards",
                "options": [{"id": str(i), "label": opt} for i, opt in enumerate(options)],
                "allowMultiple": True,
            })
        else:
            # Confirmation or reflection - just text input
            components.append({
                "type": "input",
                "variant": "freeform",
                "placeholder": "Share what comes to mind...",
            })
        
        return prompt, components
    
    async def _generate_conversational_response(
        self,
        session: IntegratedSession,
        user_message: str,
    ) -> tuple[str, list[dict]]:
        """Generate a conversational response using the Core + Face systems."""
        state = session.genesis_state
        face = session.face
        
        # Get the appropriate voice for this phase
        optimal_voice = PHASE_VOICE_MAP.get(state.phase, "oracle")
        face.set_manual_voice(optimal_voice)
        
        # Get conversation phase for voice system
        conv_phase = PHASE_TO_CONVERSATION_PHASE.get(state.phase, ConversationPhase.AWAKENING)
        
        # Build the system prompt with voice + context
        voice_prompt = face.get_system_prompt(
            context={"phase": state.phase.value},
            history=state.memory.get_last_n(10),
            phase=conv_phase,
        )
        
        # Gather cross-domain intelligence from Master agents
        master_context = session.get_master_context()
        
        # Build profile summary
        high_conf_traits = state.rubric.get_high_confidence_traits()
        profile_summary = "\n".join([
            f"- {t.name}: {t.value} ({t.confidence:.0%} confident)"
            for t in high_conf_traits[:5]
        ]) if high_conf_traits else "(Still forming initial impressions)"
        
        # Build hypotheses summary
        active_hypotheses = session.core.hypothesis_engine.get_top_hypotheses(limit=3)
        hypotheses_summary = "\n".join([
            f"- {h.trait_name} might be {h.suspected_value} ({h.confidence:.0%})"
            for h in active_hypotheses
        ]) if active_hypotheses else "(Gathering more signals)"
        
        # Use LLM to generate response
        if self._llm:
            try:
                prompt = f"""{voice_prompt}

═══════════════════════════════════════════════════════════════════════════════
                              PROFILING CONTEXT
═══════════════════════════════════════════════════════════════════════════════

Current Phase: {state.phase.value.upper()}
Turn Number: {state.conversation_turn + 1}
Profile Completion: {state.rubric.get_completion_percentage():.0f}%

HIGH-CONFIDENCE TRAITS:
{profile_summary}

ACTIVE HYPOTHESES:
{hypotheses_summary}

CONVERSATION HISTORY:
{self._format_conversation_history(state.memory.get_last_n(8))}

{f"MASTER AGENT INSIGHTS:{chr(10)}{master_context}" if master_context else ""}

═══════════════════════════════════════════════════════════════════════════════
USER'S MESSAGE: "{user_message if user_message else '(Initial contact)'}"
═══════════════════════════════════════════════════════════════════════════════

Generate a natural, flowing response that:
1. Acknowledges what they shared with genuine presence
2. Weaves in pattern observations naturally (not clinical)
3. Asks ONE penetrating follow-up question that opens depth
4. Maintains your voice persona ({optimal_voice.upper()})
5. Stays concise (2-4 sentences max)

Respond with ONLY the message text - no JSON, no formatting."""

                response = await self._llm.ainvoke(prompt)
                response_text = response.content if hasattr(response, 'content') else str(response)
                
            except Exception as e:
                logger.error(f"[GenesisProfiler] LLM error: {e}")
                response_text = self._get_fallback_question(state)
        else:
            response_text = self._get_fallback_question(state)
        
        # Build UI components
        components = [
            {"type": "text", "content": response_text, "variant": "question"},
            {
                "type": "input",
                "variant": "freeform",
                "placeholder": self._get_input_placeholder(state.phase),
                "minLength": 10,
            },
        ]
        
        return response_text, components
    
    def _format_conversation_history(self, messages: list[dict]) -> str:
        """Format conversation history for LLM context."""
        if not messages:
            return "(First interaction - no history)"
        
        lines = []
        for msg in messages:
            role = msg.get("role", "unknown").upper()
            content = msg.get("content", "")[:300]  # Truncate long messages
            lines.append(f"{role}: {content}")
        
        return "\n".join(lines)
    
    def _get_input_placeholder(self, phase: GenesisPhase) -> str:
        """Get phase-appropriate input placeholder."""
        placeholders = {
            GenesisPhase.AWAKENING: "Share what calls to you...",
            GenesisPhase.EXCAVATION: "Speak what lies beneath...",
            GenesisPhase.MAPPING: "Describe how this shows up...",
            GenesisPhase.SYNTHESIS: "Reflect on the patterns...",
            GenesisPhase.ACTIVATION: "Declare your next step...",
        }
        return placeholders.get(phase, "Speak your truth...")
    
    def _get_fallback_question(self, state: GenesisState) -> str:
        """Get a fallback question when LLM fails."""
        fallbacks = {
            GenesisPhase.AWAKENING: [
                "What draws you to this moment of self-discovery?",
                "Describe a time when you felt completely aligned with yourself.",
                "What truth are you seeking about your nature?",
            ],
            GenesisPhase.EXCAVATION: [
                "What pattern keeps repeating in your life, even when you try to change it?",
                "When do you feel most depleted, and what restores you?",
                "What truth about yourself have you been avoiding?",
            ],
            GenesisPhase.MAPPING: [
                "When faced with a major decision, what do you trust most - your gut, your heart, or your logic?",
                "Do you feel more energized when working alone or collaborating with others?",
                "Are you someone who waits for the right moment, or do you make things happen?",
            ],
            GenesisPhase.SYNTHESIS: [
                "Looking at all we've explored, what pattern emerges most clearly?",
                "How might your deepest challenge be pointing toward your greatest gift?",
                "What would change if you fully trusted your unique design?",
            ],
            GenesisPhase.ACTIVATION: [
                "What is one practice you could begin today that honors your true nature?",
                "What is the next brave step your soul is calling for?",
                "How will you remember who you are when the world tries to make you forget?",
            ],
        }
        questions = fallbacks.get(state.phase, fallbacks[GenesisPhase.AWAKENING])
        idx = state.conversation_turn % len(questions)
        return questions[idx]
    
    # =========================================================================
    # UI COMPONENT BUILDING
    # =========================================================================
    
    def _build_ui_payload(
        self,
        session: IntegratedSession,
        response_text: str,
        components: list[dict],
        signals: list[Signal],
        hypotheses: list[Hypothesis],
    ) -> dict:
        """Build the complete UI payload for the frontend."""
        state = session.genesis_state
        
        # Get phase visual theme
        theme = state.phase.theme
        
        # Get current voice info
        current_voice = session.face.current_voice
        voice_identity = current_voice.identity
        
        return {
            "type": "profiler_step",
            "phase": state.phase.value,
            "style": {
                "theme": theme.get("animation", "pulse"),
                "color": theme.get("color", "#6B21A8"),
                "accent": theme.get("accent", "#A855F7"),
                "animation": theme.get("animation", "pulse"),
                "icon": theme.get("icon", "eye"),
            },
            "components": components + [
                {
                    "type": "progress",
                    "current": state.conversation_turn + 1,
                    "phase": state.phase.value,
                    "phaseDescription": theme.get("description", ""),
                    "completion": state.rubric.get_completion_percentage(),
                }
            ],
            # Intelligence summary
            "intelligence": {
                "signalsDetected": len(signals),
                "activeHypotheses": len(hypotheses),
                "highConfidenceTraits": len(state.rubric.get_high_confidence_traits()),
                "totalTraits": len(state.rubric.get_all_traits()),
            },
            # Voice info
            "voice": {
                "id": voice_identity.id,
                "name": voice_identity.name,
                "icon": voice_identity.icon,
                "description": voice_identity.description,
            },
            # Master agent insights count
            "masterInsights": {
                "hypothesis": len(session.master_hypothesis_insights),
                "scout": len(session.master_scout_insights),
            },
            # Session metadata
            "sessionId": session.session_id,
            "turn": state.conversation_turn,
        }
    
    # =========================================================================
    # MAIN EXECUTION ENTRY POINT
    # =========================================================================
    
    async def execute(
        self,
        agent_input: AgentInput,
        model: str = None,
        session_id: str = None,
    ) -> AgentOutput:
        """
        Main execution entry point - processes user input through the complete fractal.
        
        Pipeline:
        1. Ensure SwarmBus subscription
        2. Get/create integrated session
        3. Run Profiler for pattern detection
        4. Convert signals to hypotheses
        5. Decide: probe or converse?
        6. Generate response
        7. Notify Master agents (async)
        8. Update session state
        9. Return structured output
        
        Args:
            agent_input: The AgentInput with context and userQuery
            model: Optional model override
            session_id: Session identifier
        
        Returns:
            AgentOutput with calculation, interpretation, and UI components
        """
        # Ensure SwarmBus subscription
        await self._ensure_bus_subscription()
        
        # Get or create session
        effective_session_id = session_id or str(uuid4())
        session = self._get_session(effective_session_id)
        session.touch()
        
        state = session.genesis_state
        user_message = agent_input.context.userQuery or ""
        
        # Check if this is init or real user input
        is_init = self._is_init_message(user_message)
        
        # Record user message if it's real input
        if not is_init and user_message.strip():
            state.memory.add_message("user", user_message)
            state.add_response(
                question=state.memory.messages[-2]["content"] if len(state.memory.messages) > 1 else "Initial",
                response=user_message,
            )
            logger.info(f"[GenesisProfiler] Recorded response #{len(state.responses)} for turn {state.conversation_turn}")
        
        # === PROFILER: Silent Pattern Detection ===
        signals = await self._run_profiler_analysis(session, user_message)
        
        # === HYPOTHESIS ENGINE: Convert Signals ===
        hypotheses = self._convert_signals_to_hypotheses(session, signals)
        
        # === DECISION: Probe or Converse? ===
        should_probe = self._should_probe(session, hypotheses)
        
        # === GENERATE RESPONSE ===
        if should_probe:
            response_text, components = await self._generate_probe(session, hypotheses)
        else:
            response_text, components = await self._generate_conversational_response(session, user_message)
        
        # Record assistant response in memory
        state.memory.add_message("assistant", response_text)
        
        # === NOTIFY MASTER AGENTS (async, non-blocking) ===
        if signals:
            asyncio.create_task(self._notify_master_scout(session, signals))
        if hypotheses:
            asyncio.create_task(self._notify_master_hypothesis(session, hypotheses))
        
        # === BUILD UI PAYLOAD ===
        ui_payload = self._build_ui_payload(session, response_text, components, signals, hypotheses)
        
        # === BUILD INTERPRETATION ===
        completion = state.rubric.get_completion_percentage()
        interpretation = f"""Phase: {state.phase.value.upper()}

{response_text}

═══════════════════════════════════════════════════════════════════════════════
Digital Twin Progress: {completion:.0f}%
Patterns Detected: {len(signals)} this turn | {session.total_signals_detected} total
Active Investigations: {len(hypotheses)} hypotheses
High-Confidence Traits: {len(state.rubric.get_high_confidence_traits())}
═══════════════════════════════════════════════════════════════════════════════"""

        # Calculate confidence based on completion
        confidence = min(0.95, 0.4 + (completion / 150))
        
        return AgentOutput(
            calculation={
                "phase": state.phase.value,
                "turn": state.conversation_turn,
                "totalResponses": len(state.responses),
                "completion": completion,
                "detectedSignals": len(signals),
                "totalSignals": session.total_signals_detected,
                "activeHypotheses": len(hypotheses),
                "totalHypotheses": session.total_hypotheses_created,
                "highConfidenceTraits": len(state.rubric.get_high_confidence_traits()),
                "probesSent": session.total_probes_sent,
                "sessionId": effective_session_id,
                "isProbing": should_probe,
            },
            correlations=[t.name for t in state.rubric.get_high_confidence_traits()[:5]],
            interpretationSeed=interpretation,
            visualizationData=ui_payload,
            method="genesis-fractal-v3",
            confidence=confidence,
        )
    
    # =========================================================================
    # PROTOCOL MESSAGE CREATION
    # =========================================================================
    
    def create_protocol_message(
        self,
        insight_type: str,
        payload: dict,
        confidence: float,
        hrm_validated: bool = False,
    ) -> UniversalProtocolMessage:
        """Create a protocol message for cross-agent communication."""
        return UniversalProtocolMessage(
            source_agent=self.name,
            target_layer="Orchestrator",
            insight_type=insight_type,
            confidence_score=confidence,
            payload=payload,
            hrm_validated=hrm_validated,
        )
